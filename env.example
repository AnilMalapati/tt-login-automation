# Copy to .env and fill in (never commit .env)

# ── Tradetron credentials ──────────────────────────────────────────────────────
TRADETRON_EMAIL=you@example.com
TRADETRON_PASSWORD=your_tradetron_password

# ── Kotak Neo V3 autologin (kotakneo_autologin.py) ────────────────────────────
# Only these two are needed for kotakneo_autologin.py.
# The broker label and button label are matched case-insensitively on the page.
# If the page layout changes, override with an exact XPath from DevTools:
# TRADETRON_KOTAK_XPATH=//button[normalize-space()='Auto sign in']

# ── Chrome binary (Linux server; macOS is auto-detected) ──────────────────────
# CHROME_BINARY=/opt/google/chrome/chrome
