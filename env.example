# Copy to .env and fill in your values (never commit .env)

# ── Required ───────────────────────────────────────────────────────────────────
TRADETRON_EMAIL=you@example.com
TRADETRON_PASSWORD=your_tradetron_password

# Your broker's regenerate-token URL — find it by:
#   1. Log into tradetron.tech
#   2. Go to Brokers & Exchanges → click "Renew" on your broker
#   3. Copy the URL from the browser address bar
REGEN_TOKEN_URL=https://tradetron.tech/user/broker-and-exchanges/regenerate-token/YOUR_BROKER_ID

# ── Telegram notifications (for error-retry script) ───────────────────────────
# How to set up:
#   1. Message @BotFather on Telegram → /newbot → copy the token
#   2. Message @userinfobot on Telegram → copy your chat ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=987654321

# ── Optional ───────────────────────────────────────────────────────────────────
# CHROME_BINARY=/opt/google/chrome/chrome   # only if Chrome is in a non-default location
